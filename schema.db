CREATE TABLE users (
    user_id INT UNSIGNED PRIMARY KEY,
    name VARCHAR(80) NOT NULL,
    details JSON NOT NULL,
    password VARCHAR(255) NOT NULL,
    CHECK (
        JSON_SCHEMA_VALID('{
            "type": "object",
            "properties": {
                "year": {"type": "integer"},
                "degree": {"type": "string"},
                "stream": {"type": "string"}
            },
            "required": ["year", "degree"]
        }', details)
    )
);

CREATE TABLE user_devices (
    id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    user_id INT UNSIGNED NOT NULL,
    fcm_token VARCHAR(512) NOT NULL UNIQUE,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(user_id) ON DELETE CASCADE ON UPDATE CASCADE
);

CREATE TABLE questions (
    id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    type ENUM('MCQ', 'MSQ', 'INT', 'NUM') NOT NULL,
    question TEXT NOT NULL,
    answer JSON NOT NULL,
    mark TINYINT UNSIGNED DEFAULT 1,
    negative_mark TINYINT UNSIGNED DEFAULT 0,
    CHECK (
        (CASE
            WHEN type = 'MCQ' THEN
                JSON_SCHEMA_VALID('{
                    "type": "object",
                    "properties": {
                        "correct_id": {"type": "integer"},
                        "options": {"type": "array", "items": {"type": "string"}}
                    },
                    "required": ["correct_id", "options"]
                }', answer)
            WHEN type = 'MSQ' THEN
                JSON_SCHEMA_VALID('{
                    "type": "object",
                    "properties": {
                        "correct_ids": {"type": "array", "items": {"type": "integer"}},
                        "options": {"type": "array", "items": {"type": "string"}}
                    },
                    "required": ["correct_ids", "options"]
                }', answer)
            WHEN type = 'INT' THEN
                JSON_SCHEMA_VALID('{
                    "type": "object",
                    "properties": {
                        "value": {"type": "integer"},
                        "range": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2}
                    },
                    "minProperties": 1
                }', answer)
            WHEN type = 'NUM' THEN
                JSON_SCHEMA_VALID('{
                    "type": "object",
                    "properties": {
                        "value": {"type": "number"},
                        "tolerance": {"type": "number"},
                        "range": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2}
                    },
                    "minProperties": 1
                }', answer)
            ELSE 1
        END) = 1
    ),
    CHECK (mark >= negative_mark)
);

CREATE TABLE assessments (
    id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    seq_num INT UNSIGNED NOT NULL,
    type ENUM('WEEK', 'DAY', 'MOCK') DEFAULT 'WEEK',
    title VARCHAR(255) NOT NULL,
    start_at DATETIME DEFAULT (CURRENT_DATE + INTERVAL 20 HOUR),
    end_at DATETIME,
    total_duration INT UNSIGNED DEFAULT 30,
    reminders JSON
);

CREATE TABLE assessment_questions (
    assessment_id INT UNSIGNED,
    question_id INT UNSIGNED,
    PRIMARY KEY (assessment_id, question_id),
    FOREIGN KEY (assessment_id) REFERENCES assessments(id)
    ON UPDATE CASCADE ON DELETE CASCADE,
    FOREIGN KEY (question_id) REFERENCES questions(id)
    ON UPDATE CASCADE ON DELETE RESTRICT
);

CREATE TABLE student_submissions (
    user_id INT UNSIGNED,
    assessment_id INT UNSIGNED,
    total_score DECIMAL(10,2) NOT NULL DEFAULT 0,
    total_time_sec INT UNSIGNED NOT NULL DEFAULT 0,
    detailed_log JSON NOT NULL,
    submitted_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (user_id, assessment_id),
    FOREIGN KEY (user_id) REFERENCES users(user_id) ON DELETE CASCADE,
    FOREIGN KEY (assessment_id) REFERENCES assessments(id) ON DELETE CASCADE
);

CREATE TABLE sent_notifications (
    user_id INT UNSIGNED NOT NULL,
    assessment_id INT UNSIGNED NOT NULL,
    reminder_str VARCHAR(20) NOT NULL,
    sent_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (user_id, assessment_id, reminder_str),
    FOREIGN KEY (user_id) REFERENCES users(user_id) ON UPDATE CASCADE ON DELETE CASCADE,
    FOREIGN KEY (assessment_id) REFERENCES assessments(id) ON UPDATE CASCADE ON DELETE CASCADE
);

CREATE TABLE push_queue (
    id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    assessment_id INT UNSIGNED NOT NULL,
    title VARCHAR(255) NOT NULL,
    body TEXT NOT NULL,
    status ENUM('PENDING', 'SENT') DEFAULT 'PENDING',
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (assessment_id) REFERENCES assessments(id) ON DELETE CASCADE
);

SET GLOBAL event_scheduler = ON;

CREATE EVENT IF NOT EXISTS cleanup_old_notifications
ON SCHEDULE EVERY 1 HOUR
DO
    DELETE FROM sent_notifications WHERE sent_at < NOW() - INTERVAL 1 DAY;
